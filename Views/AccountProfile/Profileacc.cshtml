@model Skill_Swap_Project.Models.User
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="max-w-4xl mx-auto py-10">

    <!-- Profile Card -->
    <div class="bg-white shadow-lg rounded-xl p-8">

        <!-- Profile Header -->
        <div class="flex items-center space-x-6">

            <div class="w-28 h-28 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-4xl font-bold border-4 border-blue-500">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>

            <div>
                <h1 class="text-3xl font-bold text-gray-800">
                    @Model.FullName
                </h1>

                <p class="text-gray-500 mt-1">
                    📍 @Model.Email
                </p>

                <a asp-controller="UserProfile" asp-action="Userprofile" class="mt-3 inline-block bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                    Refresh Profile
                </a>
            </div>

        </div>

        <!-- Skills Section -->
        <div class="mt-10">

            <h2 class="text-xl font-semibold mb-4">
                Skills I Offer
            </h2>

            <div class="flex flex-wrap gap-3">

                <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-medium">
                    @Model.Skill
                </span>

            </div>

        </div>

    </div>


    <!-- Settings Section -->
    <div class="bg-white shadow-lg rounded-xl p-8 mt-8">

        <h2 class="text-xl font-semibold mb-6">
            Account Settings
        </h2>

        <div class="space-y-4">

            <!-- Settings -->
            <a href="#"
               class="block p-4 bg-gray-100 rounded-lg hover:bg-gray-200">
                ⚙ Account Settings
            </a>

            <!-- Privacy -->
            <a href="#"
               class="block p-4 bg-gray-100 rounded-lg hover:bg-gray-200">
                🔒 Privacy Settings
            </a>

            <!-- Logout -->
            <a asp-controller="Login" asp-action="Logout"
               class="block p-4 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 font-semibold">
                🚪 Logout
            </a>

        </div>

    </div>

</div>
