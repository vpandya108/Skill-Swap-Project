@model Skill_Swap_Project.Models.User
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="min-h-screen bg-gray-100 p-6">

    <!-- Header -->
    <div class="max-w-5xl mx-auto bg-white rounded-xl shadow p-6 mb-6 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-blue-600">User Profile</h1>

        <a asp-controller="Profile" asp-action="Edit"
           class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            Edit Profile
        </a>
    </div>

    <!-- Main Layout -->
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- LEFT PROFILE CARD -->
        <div class="bg-white rounded-xl shadow p-6 text-center">

            <div class="w-28 h-28 bg-blue-100 rounded-full mx-auto mb-3 flex items-center justify-center text-blue-600 text-4xl font-bold">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>

            <h2 class="text-xl font-semibold">@Model.FullName</h2>
            <p class="text-gray-500 text-sm">@Model.Email</p>

            <p class="text-gray-400 text-sm mt-1">Skill Swap Member</p>

            <div class="flex justify-center mt-2 text-yellow-500">
                ⭐ 5.0
            </div>

        </div>

        <!-- RIGHT CONTENT -->
        <div class="lg:col-span-2 space-y-6">

            <!-- ABOUT -->
            <div class="bg-white rounded-xl shadow p-6">
                <h3 class="font-semibold text-lg mb-2">About Me</h3>

                <p class="text-gray-600 text-sm">
                    @(string.IsNullOrEmpty(Model.Bio) ? "This user hasn't added a bio yet." : Model.Bio)
                </p>
            </div>

            <!-- SKILLS -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <!-- Skills Offered -->
                <div class="bg-white rounded-xl shadow p-6">
                    <h3 class="font-semibold mb-4 text-blue-600">
                        Skills Offered
                    </h3>

                    <div class="space-y-3">

                        <div class="bg-blue-50 p-3 rounded border border-blue-100">
                            @Model.Skill
                            <span class="block text-xs text-blue-500">
                                Primary Expert
                            </span>
                        </div>

                    </div>
                </div>

                <!-- Skills Wanted -->
                <div class="bg-white rounded-xl shadow p-6">
                    <h3 class="font-semibold mb-4 text-orange-500">
                        Skills Wanted
                    </h3>

                    <div class="space-y-3">

                        <div class="bg-orange-50 p-3 rounded border border-orange-100">
                            @(string.IsNullOrEmpty(Model.LearnSkill) ? "Discovery" : Model.LearnSkill)
                            <span class="block text-xs text-orange-500">
                                Interested
                            </span>
                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>

</div>
v>

</div>