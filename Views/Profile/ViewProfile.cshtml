@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="bg-gray-100 min-h-screen p-6">

    <!-- MAIN LAYOUT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- LEFT PROFILE CARD -->
        <div class="bg-white rounded-xl shadow p-6 text-center">

            <img src="https://i.pravatar.cc/100"
                 class="mx-auto rounded-full w-24 h-24 mb-3" />

            <h2 class="text-lg font-semibold">
                Rahul Sharma
            </h2>

            <p class="text-gray-500 text-sm">
                SkillSwap Member
            </p>

            <div class="flex justify-center gap-2 mt-2 text-sm text-yellow-500">
                ⭐ 4.8
            </div>

            <p class="text-gray-400 text-sm mt-1">
                India
            </p>

            <button class="bg-blue-600 text-white w-full mt-4 py-2 rounded-lg hover:bg-blue-700">
                Send Swap Request
            </button>

            <button class="border w-full mt-2 py-2 rounded-lg text-gray-600">
                Message
            </button>

            <div class="flex justify-between mt-6 text-sm">

                <div>
                    <p class="font-bold text-blue-600">42</p>
                    <p class="text-gray-500">Swaps</p>
                </div>

                <div>
                    <p class="font-bold text-blue-600">98%</p>
                    <p class="text-gray-500">Response</p>
                </div>

            </div>

        </div>


        <!-- RIGHT CONTENT -->
        <div class="lg:col-span-2 space-y-6">

            <!-- ABOUT -->
            <div class="bg-white rounded-xl shadow p-6">

                <h2 class="font-semibold text-lg mb-2">
                    About Rahul Sharma
                </h2>

                <p class="text-gray-600 text-sm">
                    Passionate learner and teacher. Interested in sharing knowledge and growing together through SkillSwap.
                </p>

            </div>


            <!-- SKILLS -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <!-- Skills Offered -->
                <div class="bg-white rounded-xl shadow p-6">

                    <h3 class="font-semibold mb-4 text-blue-600">
                        Skills Offered
                    </h3>

                    <div class="space-y-3">

                        <div class="bg-gray-100 p-3 rounded">
                            Web Development
                            <span class="block text-xs text-blue-500">
                                Expert
                            </span>
                        </div>

                        <div class="bg-gray-100 p-3 rounded">
                            Communication
                            <span class="block text-xs text-blue-500">
                                Intermediate
                            </span>
                        </div>

                    </div>

                </div>


                <!-- Skills Wanted -->
                <div class="bg-white rounded-xl shadow p-6">

                    <h3 class="font-semibold mb-4 text-orange-500">
                        Skills Wanted
                    </h3>

                    <div class="space-y-3">

                        <div class="bg-gray-100 p-3 rounded">
                            Data Science
                            <span class="block text-xs text-orange-500">
                                Beginner
                            </span>
                        </div>

                        <div class="bg-gray-100 p-3 rounded">
                            UI/UX Design
                            <span class="block text-xs text-orange-500">
                                Intermediate
                            </span>
                        </div>

                    </div>

                </div>

            </div>


            <!-- REVIEWS -->
            <div class="bg-white rounded-xl shadow p-6">

                <h3 class="font-semibold mb-4">
                    Recent Reviews
                </h3>

                <div class="space-y-4">

                    <div class="flex gap-3">

                        <img src="https://i.pravatar.cc/40"
                             class="rounded-full" />

                        <div>
                            <p class="font-medium">Marcus Chen</p>
                            <p class="text-sm text-gray-500">
                                Great experience learning together!
                            </p>
                        </div>

                    </div>

                    <div class="flex gap-3">

                        <img src="https://i.pravatar.cc/41"
                             class="rounded-full" />

                        <div>
                            <p class="font-medium">Elena Rodriguez</p>
                            <p class="text-sm text-gray-500">
                                Very professional and helpful.
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>