@model string
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Skill Swap - Forgot Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center px-4">
    <div class="max-w-md w-full bg-white p-8 rounded-xl shadow-lg">
        <h2 class="text-2xl font-bold text-blue-600 mb-6 flex items-center gap-2">
            Skill Swap
        </h2>
        
        <h1 class="text-xl font-bold mb-2">Reset Password</h1>
        <p class="text-gray-500 mb-6 text-sm">Enter your registered email to reset your password.</p>

        @if (ViewBag.Message != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
                @ViewBag.Message
            </div>
            <a asp-action="Login" class="text-blue-600 block text-center font-medium mt-4">Go to Login →</a>
        }
        else
        {
            @if (ViewBag.Error != null)
            {
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="ForgotPassword">
                <div class="mb-4">
                    <label class="block font-medium mb-2 text-sm">Email Address</label>
                    <input type="email" name="email" class="w-full bg-gray-50 border rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-blue-400" required />
                </div>

                <div class="mb-6">
                    <label class="block font-medium mb-2 text-sm">New Password</label>
                    <input type="password" name="newPassword" class="w-full bg-gray-50 border rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-blue-400" required />
                </div>

                <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                    Reset Password
                </button>
            </form>
            
            <div class="mt-4 text-center text-sm">
                <a asp-action="Login" class="text-gray-500 hover:text-blue-600">Back to Login</a>
            </div>
        }
    </div>
</body>
</html>
