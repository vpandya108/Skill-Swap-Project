@{
    Layout = null;
}

<script src="https://cdn.tailwindcss.com"></script>
<div class="bg-white shadow mb-6">
    <div class="max-w-7xl mx-auto flex justify-between items-center p-4">

        <!-- Left Menu -->
        <div class="flex space-x-6 font-medium">

            <a asp-controller="Explore" asp-action="Exploreview"
               class="text-gray-700 hover:text-blue-600">
                Browse Skills
            </a>

            <a asp-controller="Explore" asp-action="Exploreview"
               class="text-gray-700 hover:text-blue-600">
                Explore
            </a>

            <a asp-controller="MySwap" asp-action="Swaps"
               class="text-gray-700 hover:text-blue-600">
                My Swaps
            </a>

            <a asp-controller="Message" asp-action="Chat"
               class="text-gray-700 hover:text-blue-600">
                Messages
            </a>

        </div>
        </div>
        </div>


<div class="max-w-7xl mx-auto">

    <!-- Welcome Banner -->
    <div class="bg-blue-600 text-white rounded-xl p-10 mb-8">

        <h1 class="text-4xl font-bold mb-3">
            Welcome to Skill Swap, Vishva!
        </h1>

        <p class="text-lg mb-6">
            Ready to learn something new? Connect with experts around the world
            and share your own unique passions.
        </p>

        <a asp-controller="Explore" asp-action="Explore"
           class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold">
            Start Learning
        </a>

    </div>



    <div class="grid grid-cols-3 gap-6">

        <!-- LEFT SIDE -->
        <div class="col-span-2">

            <!-- Active Swaps -->
            <div class="bg-white rounded-xl shadow p-6 mb-6">

                <div class="flex justify-between mb-4">

                    <h2 class="text-xl font-semibold">
                        My Active Swaps
                    </h2>

                    <a asp-controller="MySwaps" asp-action="Index"
                       class="text-blue-600 text-sm">
                        View All
                    </a>

                </div>


                <div class="text-center py-12 text-gray-500">

                    <div class="text-4xl mb-3">🤝</div>

                    <p class="font-medium">
                        No active swaps yet
                    </p>

                    <p class="text-sm mb-4">
                        Start browsing categories to find your first match
                        and begin exchanging knowledge!
                    </p>

                    <a asp-controller="Explore" asp-action="Explore"
                       class="bg-gray-200 px-4 py-2 rounded">
                        Browse Skills
                    </a>

                </div>

            </div>



            <!-- Recommended Skills -->
            <h2 class="text-xl font-semibold mb-4">
                Recommended Skills for You
            </h2>


            <div class="grid grid-cols-2 gap-6">


                <!-- Card 1 -->
                <div class="bg-white rounded-xl shadow">

                    <img src="https://images.unsplash.com/photo-1516035069371-29a1b244cc32"
                         class="rounded-t-xl h-40 w-full object-cover">

                    <div class="p-4">

                        <h3 class="font-semibold text-lg">
                            Digital Photography
                        </h3>

                        <p class="text-sm text-gray-500 mb-3">
                            Learn manual settings, lighting, and composition from a pro.
                        </p>

                        <div class="flex justify-between items-center">

                            <span class="text-sm text-gray-500">
                                Sarah J.
                            </span>

                            <a asp-controller="Swap" asp-action="Request"
                               class="bg-blue-600 text-white px-3 py-1 rounded">
                                Swap My Skill
                            </a>

                        </div>

                    </div>

                </div>



                <!-- Card 2 -->
                <div class="bg-white rounded-xl shadow">

                    <img src="https://images.unsplash.com/photo-1555949963-aa79dcee981c"
                         class="rounded-t-xl h-40 w-full object-cover">

                    <div class="p-4">

                        <h3 class="font-semibold text-lg">
                            Python Programming
                        </h3>

                        <p class="text-sm text-gray-500 mb-3">
                            Master automation, data analysis and backend basics.
                        </p>

                        <div class="flex justify-between items-center">

                            <span class="text-sm text-gray-500">
                                David L.
                            </span>

                            <a asp-controller="Swap" asp-action="Request"
                               class="bg-blue-600 text-white px-3 py-1 rounded">
                                Swap My Skill
                            </a>

                        </div>

                    </div>

                </div>



                <!-- Card 3 -->
                <div class="bg-white rounded-xl shadow">

                    <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c"
                         class="rounded-t-xl h-40 w-full object-cover">

                    <div class="p-4">

                        <h3 class="font-semibold text-lg">
                            Vegan Cooking
                        </h3>

                        <p class="text-sm text-gray-500 mb-3">
                            Learn delicious plant-based recipes and nutrition tips.
                        </p>

                        <div class="flex justify-between items-center">

                            <span class="text-sm text-gray-500">
                                Elena R.
                            </span>

                            <a asp-controller="Swap" asp-action="Request"
                               class="bg-blue-600 text-white px-3 py-1 rounded">
                                Swap My Skill
                            </a>

                        </div>

                    </div>

                </div>



                <!-- Card 4 -->
                <div class="bg-white rounded-xl shadow">

                    <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7"
                         class="rounded-t-xl h-40 w-full object-cover">

                    <div class="p-4">

                        <h3 class="font-semibold text-lg">
                            Graphic Design
                        </h3>

                        <p class="text-sm text-gray-500 mb-3">
                            Brand identity, typography, and Adobe Creative Suite.
                        </p>

                        <div class="flex justify-between items-center">

                            <span class="text-sm text-gray-500">
                                Marc T.
                            </span>

                            <a asp-controller="Swap" asp-action="Request"
                               class="bg-blue-600 text-white px-3 py-1 rounded">
                                Swap My Skill
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>



        <!-- RIGHT SIDE -->
        <div class="space-y-6">

            <!-- Skills -->
            <div class="bg-white p-6 rounded-xl shadow">

                <h3 class="font-semibold mb-4">
                    My Skills for Swap
                </h3>

                <div class="flex justify-between items-center bg-gray-100 p-3 rounded mb-3">

                    <span>Web Development</span>

                    <a asp-controller="Profile" asp-action="EditSkill">
                        ✏️
                    </a>

                </div>

                <a asp-controller="Profile" asp-action="AddSkill"
                   class="border border-dashed w-full py-2 rounded text-gray-500 block text-center">

                    + Add New Skill

                </a>

            </div>



            <!-- Impact -->
            <div class="bg-gray-900 text-white p-6 rounded-xl">

                <h3 class="mb-4 font-semibold">
                    Your Impact
                </h3>

                <div class="flex justify-between text-center">

                    <div>
                        <p class="text-3xl font-bold">0</p>
                        <p class="text-sm text-gray-400">
                            Skills Learned
                        </p>
                    </div>

                    <div>
                        <p class="text-3xl font-bold">1</p>
                        <p class="text-sm text-gray-400">
                            Skills Offered
                        </p>
                    </div>

                </div>

            </div>



            <!-- Recent Swaps -->
            <div class="bg-white p-6 rounded-xl shadow">

                <h3 class="font-semibold mb-4">
                    Recent Swaps
                </h3>

                <p class="text-sm text-gray-500 mb-2">
                    Anna learned
                    <a asp-controller="Explore" asp-action="Explore"
                       class="text-blue-600">Piano</a>
                    from Lucas.
                </p>

                <p class="text-sm text-gray-500">
                    Sam just listed
                    <a asp-controller="Explore" asp-action="Explore"
                       class="text-blue-600">Spanish</a>
                    as a new skill!
                </p>

            </div>

        </div>

    </div>

</div>