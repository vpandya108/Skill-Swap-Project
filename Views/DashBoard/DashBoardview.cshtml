@model List<Skill_Swap_Project.Models.User>
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<script src="https://cdn.tailwindcss.com"></script>

<!-- MAIN CONTAINER -->
<div class="max-w-7xl mx-auto px-8 py-6">

    <!-- Welcome Banner -->
    <div class="bg-blue-600 text-white rounded-xl p-10 mb-8">

        <h1 class="text-4xl font-bold mb-3">
            Welcome to Skill Swap, @Context.Session.GetString("UserName")!
        </h1>

        <p class="text-lg mb-6">
            Ready to learn something new? Connect with experts around the world
            and share your own unique passions.
        </p>

        <a asp-controller="Explore" asp-action="Exploreview"
           class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold">
            Start Learning
        </a>

    </div>


    <!-- GRID LAYOUT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- LEFT SECTION -->
        <div class="lg:col-span-2">

            <!-- Active Swaps -->
            <div class="bg-white rounded-xl shadow p-6 mb-6">

                <div class="flex justify-between mb-4">

                    <h2 class="text-xl font-semibold">
                        My Active Swaps
                    </h2>

                    <a asp-controller="Swap" asp-action="MySwaps"
                       class="text-blue-600 text-sm">
                        View All
                    </a>

                </div>

                @if (ViewBag.ActiveSwaps == 0)
                {
                    <div class="text-center py-12 text-gray-500">
                        <div class="text-4xl mb-3">🤝</div>
                        <p class="font-medium">No active swaps yet</p>
                        <p class="text-sm mb-4">Start browsing categories to find your first match!</p>
                        <a asp-controller="Explore" asp-action="Exploreview" class="bg-blue-100 text-blue-600 px-4 py-2 rounded">
                            Browse Skills
                        </a>
                    </div>
                }
                else
                {
                    <div class="p-6 bg-green-50 rounded-lg text-green-700">
                        You have <b>@ViewBag.ActiveSwaps</b> active connection(s). 
                        Check <a asp-controller="Swap" asp-action="MySwaps" class="underline font-bold">My Swaps</a> for details.
                    </div>
                }

            </div>


            <!-- Recommended Skills -->
            <h2 class="text-xl font-semibold mb-4">
                Recommended Skills for You
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                @foreach (var user in Model)
                {
                    <!-- Card -->
                    <div class="bg-white rounded-xl shadow hover:shadow-lg transition duration-300 overflow-hidden">
                        <div class="h-40 bg-blue-500 flex items-center justify-center text-white text-3xl font-bold">
                            @user.Skill.Substring(0, 1).ToUpper()
                        </div>

                        <div class="p-4">

                            <h3 class="font-semibold text-lg">
                                @user.Skill
                            </h3>

                            <p class="text-sm text-gray-500 mb-3 line-clamp-2">
                                @(string.IsNullOrEmpty(user.Bio) ? "Explore this exciting skill from an expert in the field." : user.Bio)
                            </p>

                            <div class="flex justify-between items-center">

                                <span class="text-sm text-gray-500">
                                    @user.FullName
                                </span>

                                <form asp-controller="Swap" asp-action="RequestSwap" method="post">
                                    <input type="hidden" name="receiverId" value="@user.Id" />
                                    <button type="submit" class="bg-blue-600 text-white px-3 py-1 rounded text-sm">
                                        Swap Now
                                    </button>
                                </form>

                            </div>

                        </div>

                    </div>
                }

                @if(!Model.Any())
                {
                    <p class="text-gray-500 italic">No recommendations yet. Join the community to see more!</p>
                }

            </div>

        </div>



        <!-- RIGHT SECTION -->
        <div class="space-y-6">

            <!-- My Skills -->
            <div class="bg-white p-6 rounded-xl shadow">

                <h3 class="font-semibold mb-4">
                    My Skills for Swap
                </h3>

                <div class="flex justify-between items-center bg-gray-100 p-3 rounded mb-3">
                    <span>@Context.Session.GetString("UserSkill")</span>
                    <a asp-controller="Profile" asp-action="Userprofile">✏️</a>
                </div>

                <a asp-controller="Profile" asp-action="Edit"
                   class="border border-dashed w-full py-2 rounded text-gray-500 block text-center">
                    + Update Bio & Skills
                </a>

            </div>


            <!-- Impact -->
            <div class="bg-gray-900 text-white p-6 rounded-xl">

                <h3 class="mb-4 font-semibold">
                    Your Impact
                </h3>

                <div class="flex justify-between text-center">

                    <div>
                        <p class="text-3xl font-bold">0</p>
                        <p class="text-sm text-gray-400">
                            Skills Learned
                        </p>
                    </div>

                    <div>
                        <p class="text-3xl font-bold">@ViewBag.SkillsOffered</p>
                        <p class="text-sm text-gray-400">
                            Skills Offered
                        </p>
                    </div>

                </div>

            </div>


            <!-- Community News -->
            <div class="bg-white p-6 rounded-xl shadow">

                <h3 class="font-semibold mb-4">
                    Recent Activity
                </h3>

                <p class="text-sm text-gray-500 mb-2">
                    Multiple users have joined the platform today!
                </p>

                <p class="text-sm text-gray-400 italic">
                    Start a swap to grow your impact.
                </p>

            </div>

        </div>

    </div>

</div>
