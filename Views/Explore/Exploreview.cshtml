@model IEnumerable<Skill_Swap_Project.Models.User>
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex">

    <!-- SIDEBAR -->
    <div class="w-64 bg-white shadow-md p-5 min-h-screen">

        <h2 class="text-xl font-bold text-blue-600 mb-6">
            SkillSwap
        </h2>

        <ul class="space-y-4 text-gray-600">

            <li>
                <a asp-controller="Dashboard" asp-action="DashBoardview" class="hover:text-blue-600">
                    Dashboard
                </a>
            </li>

            <li class="text-blue-600 font-medium">
                <a asp-controller="Explore" asp-action="Exploreview">
                    Discover
                </a>
            </li>

            <li>
                <a asp-controller="Swap" asp-action="MySwaps" class="hover:text-blue-600">
                    My Swaps
                </a>
            </li>

            <li>
                <a asp-controller="Message" asp-action="Chat" class="hover:text-blue-600">
                    Messages
                </a>
            </li>
        </ul>

        <a asp-controller="Profile" asp-action="Edit"
           class="block mt-6 w-full text-center bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
            Edit My Profile
        </a>

    </div>


    <!-- MAIN CONTENT -->
    <div class="flex-1 px-6 py-6 bg-gray-100 min-h-screen">

        <!-- TOP NAV -->
        <div class="flex justify-between items-center mb-6">

            <h1 class="text-2xl font-bold">
                Explore Opportunities
            </h1>

        </div>

        @if (TempData["Message"] != null)
        {
            <div class="bg-green-500 text-white p-4 rounded-lg mb-6 shadow-md animate-pulse">
                @TempData["Message"]
            </div>
        }


        <!-- SEARCH -->
        <form method="get" asp-action="Exploreview" class="mb-6">
            <div class="flex gap-2">
                <input type="text"
                       name="searchTerm"
                       placeholder="Search skills, industries, or experts..."
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400 focus:outline-none" />
                <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
                    Search
                </button>
            </div>
        </form>


        <!-- CARDS GRID -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            @if (!Model.Any())
            {
                <div class="col-span-full text-center py-12 bg-white rounded-xl shadow">
                    <p class="text-gray-500">No users found matching your search.</p>
                </div>
            }

            @foreach (var user in Model)
            {
                <!-- USER CARD -->
                <div class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition">

                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">
                            @user.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <h3 class="font-semibold">@user.FullName</h3>
                            <p class="text-xs text-gray-500">Skill Expert</p>
                        </div>
                    </div>

                    <p class="text-xs text-gray-400">I CAN TEACH</p>
                    <div class="bg-blue-100 text-blue-600 px-3 py-1 rounded mt-1 inline-block text-sm">
                        @user.Skill
                    </div>

                    <p class="text-xs text-gray-400 mt-3">I WANT TO LEARN</p>
                    <div class="bg-orange-100 text-orange-600 px-3 py-1 rounded mt-1 inline-block text-sm">
                        @(string.IsNullOrEmpty(user.LearnSkill) ? "Discovery" : user.LearnSkill)
                    </div>

                    <div class="mt-4 space-y-2">

                        <a asp-controller="Profile"
                           asp-action="Userprofile"
                           asp-route-id="@user.Id"
                           class="block text-center bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
                            View Profile
                        </a>

                        <form asp-controller="Swap" asp-action="RequestSwap" method="post">
                            <input type="hidden" name="receiverId" value="@user.Id" />
                            <button type="submit" class="w-full border py-2 rounded text-gray-600 hover:bg-gray-100">
                                Send Swap Request
                            </button>
                        </form>

                    </div>

                </div>
            }

        </div>

    </div>

</div>
